# S3 Conditional Writes Test Suite — Sample Configuration
#
# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and will not be committed.
#
# Environment variables always take precedence over values in this file.
# You can also point to a custom config file path via S3_CONFIG_FILE:
#   S3_CONFIG_FILE=/path/to/my.env go test -tags integration ./s3test/

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# S3 bucket to run tests against. The bucket must already exist.
S3_BUCKET=my-test-bucket

# ---------------------------------------------------------------------------
# Optional — AWS / S3-compatible endpoint
# ---------------------------------------------------------------------------

# Leave S3_ENDPOINT empty to target real AWS S3.
# Set it for MinIO, LocalStack, Ceph, or any other S3-compatible service.
S3_ENDPOINT=
# S3_ENDPOINT=http://localhost:9000          # MinIO (local)
# S3_ENDPOINT=http://localhost:4566          # LocalStack

# AWS region (default: us-east-1)
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Optional — Credentials
# ---------------------------------------------------------------------------

# Leave these empty to use the default AWS credential chain
# (environment variables → ~/.aws/credentials → EC2/ECS instance role, etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Temporary-credential session token (STS, assume-role, SSO, etc.)
AWS_SESSION_TOKEN=

# ---------------------------------------------------------------------------
# Optional — Addressing style
# ---------------------------------------------------------------------------

# Force path-style addressing (bucket.s3.amazonaws.com vs s3.amazonaws.com/bucket).
# Defaults to true when S3_ENDPOINT is set (required by MinIO and LocalStack).
# Set to false when using a custom endpoint that supports virtual-hosted style.
S3_PATH_STYLE=
